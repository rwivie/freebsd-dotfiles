#!/bin/sh

case "$1" in
    --toggle)
        if [ "$(pgrep -x polybar)" ]; then
            pkill polybar
        else
            ~/.config/dk/polybar/launch.sh &
        fi
        ;;
    *)
        if [ "$(pgrep -x polybar)" ]; then
            echo "󰨚"
        else
            echo "󰨙"
        fi
        ;;
esac